{
  "name": "syncpulse-pro",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "start": "npm --prefix apps/web run start",
    "typecheck": "npm run --workspaces --if-present typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}